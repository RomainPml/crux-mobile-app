{
  "name": "crux",
  "private": true,
  "scripts": {
    "api": "pnpm --filter @crux/api dev",
    "mobile": "pnpm --filter @crux/mobile start",
    "shared:build": "pnpm --filter @crux/shared build",
    "db:migrate": "pnpm --filter @crux/api prisma:migrate",
    "db:seed": "pnpm --filter @crux/api prisma:seed",
    "test": "pnpm --filter @crux/api test"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "prisma", "esbuild"]
  }
}
