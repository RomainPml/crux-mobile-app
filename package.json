{
  "name": "crux",
  "private": true,
  "scripts": {
    "api": "tsx watch --env-file=apps/api/.env apps/api/src/index.ts",
    "mobile": "NODE_OPTIONS='--no-experimental-require-module' expo start apps/mobile",
    "shared:build": "pnpm --filter @crux/shared build",
    "db:migrate": "pnpm --filter @crux/api prisma:migrate",
    "db:seed": "pnpm --filter @crux/api prisma:seed",
    "test": "vitest --run --root apps/api",
    "test:shared": "vitest --run --root packages/shared"
  },
  "devDependencies": {
    "jscodeshift": "^17.3.0"
  }
}
