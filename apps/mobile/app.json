{
  "expo": {
    "name": "Crux",
    "slug": "crux",
    "version": "0.0.1",
    "scheme": "crux",
    "platforms": ["ios", "android"],
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.crux.app",
      "supportsTablet": true,
      "associatedDomains": ["applinks:crux.app"]
    },
    "android": {
      "package": "com.crux.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "crux.app",
              "pathPrefix": "/l/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
